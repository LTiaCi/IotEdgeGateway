#!/bin/sh

APP_NAME=iotgw_gateway
APP_DIR=/opt/iotgw_package
APP_START="$APP_DIR/start.sh"
PID_FILE=/var/run/iotgw_gateway.pid
LOG_FILE=/tmp/iotgw_gateway.log

wait_for_mqtt() {
    i=0
    while [ "$i" -lt 20 ]; do
        if command -v netstat >/dev/null 2>&1 && netstat -lnt 2>/dev/null | grep -q ':1883 '; then
            return 0
        fi
        if command -v mosquitto_pub >/dev/null 2>&1 && mosquitto_pub -h 127.0.0.1 -p 1883 -t iotgw/boot/check -m ok >/dev/null 2>&1; then
            return 0
        fi
        i=$((i + 1))
        sleep 1
    done
    return 0
}

start() {
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "$APP_NAME already running"
        return 0
    fi

    if [ ! -x "$APP_START" ]; then
        echo "$APP_START not found or not executable"
        return 1
    fi

    wait_for_mqtt

    cd "$APP_DIR" || return 1
    nohup "$APP_START" >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    echo "$APP_NAME started"
}

stop() {
    if [ -f "$PID_FILE" ]; then
        kill "$(cat "$PID_FILE")" 2>/dev/null || true
        rm -f "$PID_FILE"
    fi
    killall iotgw_gateway 2>/dev/null || true
    killall gst-launch-1.0 2>/dev/null || true
    killall ffmpeg 2>/dev/null || true
    echo "$APP_NAME stopped"
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        sleep 1
        start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
