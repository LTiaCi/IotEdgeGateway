#!/bin/sh

APP_NAME=wifi_jk
IFACE="${WIFI_IFACE:-wlan0}"
SSID="jk"
PSK="woniu@jiankong.com"
LOG_FILE=/tmp/wifi_jk.log

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $*" >> "$LOG_FILE"
}

wait_for_iface() {
    i=0
    while [ "$i" -lt 20 ]; do
        if [ -d "/sys/class/net/$IFACE" ]; then
            return 0
        fi
        i=$((i + 1))
        sleep 1
    done
    return 1
}

renew_ip() {
    if command -v udhcpc >/dev/null 2>&1; then
        killall udhcpc 2>/dev/null || true
        udhcpc -i "$IFACE" -q -t 8 >> "$LOG_FILE" 2>&1 || true
    elif command -v dhcpcd >/dev/null 2>&1; then
        dhcpcd "$IFACE" >> "$LOG_FILE" 2>&1 || true
    fi
}

connect_with_nmcli() {
    command -v nmcli >/dev/null 2>&1 || return 1
    nmcli dev wifi connect "$SSID" password "$PSK" ifname "$IFACE" >> "$LOG_FILE" 2>&1
}

connect_with_wpa_cli() {
    command -v wpa_cli >/dev/null 2>&1 || return 1

    wpa_cli -i "$IFACE" status >/dev/null 2>&1 || return 1

    NET_ID="$(wpa_cli -i "$IFACE" add_network 2>/dev/null | tail -n 1)"
    [ -n "$NET_ID" ] || return 1

    wpa_cli -i "$IFACE" set_network "$NET_ID" ssid "\"$SSID\"" >> "$LOG_FILE" 2>&1 || return 1
    wpa_cli -i "$IFACE" set_network "$NET_ID" psk "\"$PSK\"" >> "$LOG_FILE" 2>&1 || return 1
    wpa_cli -i "$IFACE" enable_network "$NET_ID" >> "$LOG_FILE" 2>&1 || return 1
    wpa_cli -i "$IFACE" select_network "$NET_ID" >> "$LOG_FILE" 2>&1 || return 1
    wpa_cli -i "$IFACE" save_config >> "$LOG_FILE" 2>&1 || true
}

connect_with_wpa_supplicant() {
    command -v wpa_supplicant >/dev/null 2>&1 || return 1

    CONF=/tmp/wifi_jk_wpa_supplicant.conf
    cat > "$CONF" <<EOF
ctrl_interface=/var/run/wpa_supplicant
update_config=1
network={
    ssid="$SSID"
    psk="$PSK"
    key_mgmt=WPA-PSK
}
EOF

    killall wpa_supplicant 2>/dev/null || true
    wpa_supplicant -B -i "$IFACE" -c "$CONF" >> "$LOG_FILE" 2>&1
}

start() {
    : > "$LOG_FILE"
    log "$APP_NAME start iface=$IFACE ssid=$SSID"

    if ! wait_for_iface; then
        log "interface $IFACE not found"
        return 1
    fi

    ip link set "$IFACE" up >> "$LOG_FILE" 2>&1 || ifconfig "$IFACE" up >> "$LOG_FILE" 2>&1 || true

    if connect_with_nmcli; then
        log "connected by nmcli"
    elif connect_with_wpa_cli; then
        log "connected by wpa_cli"
    elif connect_with_wpa_supplicant; then
        log "connected by wpa_supplicant"
    else
        log "failed to start WiFi connection"
        return 1
    fi

    sleep 3
    renew_ip
    ip addr show "$IFACE" >> "$LOG_FILE" 2>&1 || ifconfig "$IFACE" >> "$LOG_FILE" 2>&1 || true
    log "$APP_NAME done"
}

stop() {
    log "$APP_NAME stop"
    killall udhcpc 2>/dev/null || true
}

case "$1" in
    start|"")
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        sleep 1
        start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
